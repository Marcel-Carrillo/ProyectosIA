DATABASE_URL="postgresql://ecommerceUser:ecommercePassword@localhost:5432/ecommerceDb"
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3000

# Admin auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPass1
ADMIN_JWT_SECRET=change-me-admin-jwt-secret-min-32-chars
ADMIN_JWT_EXPIRES_IN=15m
# Used by cookie-parser to sign/verify cookies
COOKIE_SECRET=change-me-cookie-secret-min-32-chars

# Customer auth
CUSTOMER_JWT_SECRET=change-me-customer-jwt-secret-min-32-chars
CUSTOMER_JWT_EXPIRES_IN=15m

# SMTP (password reset emails — use Mailpit locally: docker compose up -d mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
# Set SMTP_STRICT=true to fail forgot-password when SMTP is unreachable
SMTP_STRICT=false
MAILPIT_API_URL=http://localhost:8025/api/v1

# Stripe payments
# STRIPE_MODE controls whether test or live keys are expected (test|live)
STRIPE_MODE=test
# Secret key — NEVER expose in API responses or client code
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key
# Publishable key — safe to send to the browser via GET /api/public/payments/config
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_stripe_publishable_key
# Webhook signing secret — obtained from Stripe Dashboard or `stripe listen` output
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# To forward webhooks locally: stripe listen --forward-to http://localhost:3000/api/public/payments/webhook

# OAuth (optional — leave empty until provider credentials are available)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PEM contents with literal \n line breaks, or single-line env value
APPLE_PRIVATE_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
