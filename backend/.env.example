DATABASE_URL="postgresql://ecommerceUser:ecommercePassword@localhost:5432/ecommerceDb"
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# Admin auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPass1
ADMIN_JWT_SECRET=change-me-admin-jwt-secret-min-32-chars
ADMIN_JWT_EXPIRES_IN=15m

# Customer auth
CUSTOMER_JWT_SECRET=change-me-customer-jwt-secret-min-32-chars
CUSTOMER_JWT_EXPIRES_IN=15m

# SMTP (password reset emails)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# OAuth (optional — leave empty for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
