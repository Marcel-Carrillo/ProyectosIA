# ──────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES — Reference for local development
#
#  Development (host-local):   copy to  .env
#  Development (Docker):       copy to  .env.docker
#  Production (Lambda):        all vars are stored in AWS SSM Parameter Store
#                              and read by serverless.yml at deploy time.
#                              Update them with:
#                              aws ssm put-parameter --name /ecommerce/prod/VARNAME \
#                                --value "VALUE" --type SecureString --overwrite
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────────────────────
# Host-local (backend on host, Postgres exposed on localhost:5432):
DATABASE_URL="postgresql://ecommerceUser:ecommercePassword@localhost:5432/ecommerceDb"
# Docker (backend inside docker-compose, use service name 'db'):
# DATABASE_URL="postgresql://ecommerceUser:ecommercePassword@db:5432/ecommerceDb"

PORT=3000
NODE_ENV=development

# URLs — dev uses localhost; prod values come from SSM
FRONTEND_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3000

# ── Admin auth ─────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPass1
ADMIN_JWT_SECRET=change-me-admin-jwt-secret-min-32-chars
ADMIN_JWT_EXPIRES_IN=15m
COOKIE_SECRET=change-me-cookie-secret-min-32-chars

# ── Customer auth ──────────────────────────────────────────────────────────────
CUSTOMER_JWT_SECRET=change-me-customer-jwt-secret-min-32-chars
CUSTOMER_JWT_EXPIRES_IN=15m

# ── SMTP (emails) ─────────────────────────────────────────────────────────────
# Dev: Mailpit catches all outgoing mail — no real SMTP credentials needed
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=mcarhue@mavile.es
# Set true in production to fail hard if SMTP is unreachable (serverless.yml sets this)
SMTP_STRICT=false
MAILPIT_API_URL=http://localhost:8025/api/v1
# Production: mavile.es uses Microsoft 365 (smtp.office365.com:587, STARTTLS)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=mcarhue@mavile.es
# SMTP_PASS=<Microsoft 365 password or app password>

# ── Welcome coupon ─────────────────────────────────────────────────────────────
# Sent on new customer registration. One use per customer account.
WELCOME_COUPON_PERCENT=15
WELCOME_COUPON_MIN_ORDER=0

# ── Stripe payments ───────────────────────────────────────────────────────────
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_test_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_stripe_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_stripe_test_webhook_secret

# ── OAuth (optional — leave empty unless testing OAuth flows locally) ──────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Production SSM parameters to create/update ────────────────────────────────
# aws ssm put-parameter --name /ecommerce/prod/DATABASE_URL        --value "..." --type SecureString --overwrite
# aws ssm put-parameter --name /ecommerce/prod/FRONTEND_URL        --value "https://mavile.es" --type String --overwrite
# aws ssm put-parameter --name /ecommerce/prod/API_PUBLIC_URL      --value "https://API_GATEWAY_URL/prod" --type String --overwrite
# aws ssm put-parameter --name /ecommerce/prod/ADMIN_JWT_SECRET    --value "..." --type SecureString --overwrite
# aws ssm put-parameter --name /ecommerce/prod/ADMIN_JWT_EXPIRES_IN --value "15m" --type String --overwrite
# aws ssm put-parameter --name /ecommerce/prod/CUSTOMER_JWT_SECRET --value "..." --type SecureString --overwrite
# aws ssm put-parameter --name /ecommerce/prod/CUSTOMER_JWT_EXPIRES_IN --value "15m" --type String --overwrite
# aws ssm put-parameter --name /ecommerce/prod/COOKIE_SECRET       --value "..." --type SecureString --overwrite
# aws ssm put-parameter --name /ecommerce/prod/SMTP_HOST           --value "smtp.office365.com" --type String --overwrite
# aws ssm put-parameter --name /ecommerce/prod/SMTP_PORT           --value "587" --type String --overwrite
# aws ssm put-parameter --name /ecommerce/prod/SMTP_SECURE         --value "false" --type String --overwrite
# aws ssm put-parameter --name /ecommerce/prod/SMTP_USER           --value "mcarhue@mavile.es" --type String --overwrite
# aws ssm put-parameter --name /ecommerce/prod/SMTP_PASS           --value "<M365 password>" --type SecureString --overwrite
# aws ssm put-parameter --name /ecommerce/prod/SMTP_FROM           --value "mcarhue@mavile.es" --type String --overwrite
# aws ssm put-parameter --name /ecommerce/prod/STRIPE_SECRET_KEY   --value "sk_live_..." --type SecureString --overwrite
# aws ssm put-parameter --name /ecommerce/prod/STRIPE_PUBLISHABLE_KEY --value "pk_live_..." --type String --overwrite
# aws ssm put-parameter --name /ecommerce/prod/STRIPE_WEBHOOK_SECRET --value "whsec_..." --type SecureString --overwrite
