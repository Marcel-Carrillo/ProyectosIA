# ── Development (.env.development) ────────────────────────────────────────────
# Copy this section to .env.development for local development:
#
# REACT_APP_API_BASE_URL=http://localhost:3000
# REACT_APP_SITE_URL=http://localhost:3001
# PORT=3001

# ── Production (.env.production) ──────────────────────────────────────────────
# In CI/CD (deploy.yml) the GitHub Actions secret REACT_APP_API_BASE_URL is
# injected at build time automatically — no .env.production file is needed.
#
# For a manual local production build, create .env.production with:
#   REACT_APP_API_BASE_URL=<API Gateway Invoke URL from AWS Console>
#
# Example (replace with the real URL from AWS Console → API Gateway → Stages → prod):
#   REACT_APP_API_BASE_URL=https://xxxxxxxxxx.execute-api.eu-north-1.amazonaws.com/prod
#
# REACT_APP_SITE_URL is the public storefront origin used for canonical URLs,
# Open Graph tags, and JSON-LD. Not sensitive — safe to commit directly in
# .env.production (do not add it to GitHub Secrets).
#   REACT_APP_SITE_URL=https://mavile.es
